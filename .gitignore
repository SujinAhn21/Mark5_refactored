# === 제외 (커밋 안 함) ===

# Python 캐시
__pycache__/
*.py[cod]
*$py.class

# 가상환경
.venv/
venv/
env/

# 에디터/IDE 로컬 설정
.vscode/
.idea/

# OS 파일
.DS_Store
Thumbs.db

# 오디오 원본/전처리 데이터 (용량 커서 제외)
*.wav
*.mp3
*.m4a
*.flac

# 생성되는 데이터 인덱스/중간 산출물
dataset_*.csv
*.pkl
cache/

# 실행 로그
*.log
logFiles/

